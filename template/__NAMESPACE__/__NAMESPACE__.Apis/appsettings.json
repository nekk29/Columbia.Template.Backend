{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "$(ConnectionStrings.DefaultConnection)"
  },
  "ApiOptions": {
    "BasePath": "",
    "Name": "__CLIENT_DESCRIPTION__",
    "Version": "$(ApiOptions.Version)",
    "Environment": "$(ApiOptions.Environment)",
    "ContactName": "devops@yourdomain.com",
    "ContactUrl": "https://yourdomain.com/en/contact-us"
  },
  "AppSettings": {
    "DefaultCulture": "es-ES"
  },
  "SignInOptions": {
    "LockoutEnabled": true,
    "SendMailOnSignUp": true,
    "LockoutMaxFailedAccessAttempts": 3,
    "LockoutDefaultTimeSpanInMinutes": 5
  },
  "SecurityOptions": {
    "FrontUrl": "$(SecurityOptions.FrontUrl)",
    "FrontUrlLogo": "$(SecurityOptions.FrontUrlLogo)",
    "Issuer": "$(SecurityOptions.Issuer)",
    "Audience": "__CLIENT_CODE__",
    "ExpirationInSeconds": "3600",
    "SecurityKey": "[CLIENT_SECRET_HASH]",
    "CertificatePassword": "$(SecurityOptions.CertificatePassword)"
  },
  "SmptOptions": {
    "Server": "$(SmptOptions.Server)",
    "Port": "$(SmptOptions.Port)",
    "From": "$(SmptOptions.From)",
    "FromDisplay": "$(SmptOptions.FromDisplay)",
    "Mail": "$(SmptOptions.Mail)",
    "Password": "$(SmptOptions.Password)"
  }
}
