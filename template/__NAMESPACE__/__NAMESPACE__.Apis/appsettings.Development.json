{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "ApiOptions": {
    "BasePath": "",
    "Name": "__CLIENT_DESCRIPTION__",
    "Version": "Latest",
    "Environment": "Development",
    "ContactName": "devops@yourdomain.com",
    "ContactUrl": "https://yourdomain.com/en/contact-us"
  },
  "AppSettings": {
    "DefaultCulture": "es-ES"
  },
  "SignInOptions": {
    "LockoutEnabled": true,
    "SendMailOnSignUp": true,
    "LockoutMaxFailedAccessAttempts": 3,
    "LockoutDefaultTimeSpanInMinutes": 5
  },
  "SecurityOptions": {
    "FrontUrl": "https://localhost:4200",
    "FrontUrlLogo": "https://localhost:4200/assets/media/logos/default-dark.png",
    "Issuer": "https://localhost:7202",
    "Audience": "__CLIENT_CODE__",
    "ExpirationInSeconds": "3600",
    "SecurityKey": "[CLIENT_SECRET_HASH]",
    "CertificatePassword": "changeit"
  },
  "SmptOptions": {
    "Server": "",
    "Port": "",
    "From": "",
    "FromDisplay": "",
    "Mail": "",
    "Password": ""
  }
}
